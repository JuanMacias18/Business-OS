# Copiar a .env.local y completar. Nunca commitear .env.local (ya está en .gitignore).
# Valores para desarrollo local: correr `supabase start` e imprime estas dos URLs/keys en su salida.

# URL del stack local de Supabase (API_URL en la salida de `supabase start`).
VITE_SUPABASE_URL=http://127.0.0.1:54321

# Anon key local (ANON_KEY en la salida de `supabase start`). Nunca la service_role key aquí.
VITE_SUPABASE_ANON_KEY=your-local-anon-key-here
